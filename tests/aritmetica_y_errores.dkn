// --- PRUEBAS MATEMÁTICAS BÁSICAS Y LÍMITES ---

print("1. Probando constantes:");
print(PI);      // Esperado: 3.141592...
print(E);   // Esperado: 2.718281...

print("2. Probando precedencia (esperado 14):");
resultado = 2 + 3 * 4;
print(resultado);

print("3. Probando funciones trigonométricas:");
print(sin(0));  // Esperado: 0.0
print(cos(0));  // Esperado: 1.0

print("4. FORZANDO ERRORES MATEMÁTICOS:");

