// --- PRUEBAS DE CONTROL DE FLUJO ---

print("1. Probando Bucle FOR:");
// Calcular suma de los primeros 5 números
suma = 0;
for (i = 1; i <= 5; i = i + 1) {
    suma = suma + i;
}
print("Suma del 1 al 5:");
print(suma); // Esperado: 15

print("2. Probando IF / ELSE (simulado):");
limite = 10;
if (suma > limite) {
    print("La suma superó el límite.");
}

print("3. Probando Infinito:");
print(INF);
if (INF > 999999) {
    print("El valor es infinito.");
}
